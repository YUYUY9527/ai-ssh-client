{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI SSH Client",
  "version": "1.0.0",
  "identifier": "com.aisshclient.app",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:renderer",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "windows": [
      {
        "title": "AI SSH Client",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "../build/icon.ico",
      "../build/icon-1024.png"
    ]
  }
}
