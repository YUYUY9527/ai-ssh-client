{
  "name": "ai-ssh-client",
  "version": "1.0.0",
  "description": "AI-powered SSH client with natural language control",
  "scripts": {
    "dev": "tauri dev",
    "dev:vite": "vite",
    "dev:tauri": "tauri dev",
    "build": "tauri build",
    "build:renderer": "vite build",
    "build:tauri": "tauri build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:sentinel": "vitest run sentinel",
    "test:history": "vitest run command-history-index",
    "test:sftp": "vitest run sftp-items sftp-upload sftp-transfer",
    "test:ui": "vitest run ui-design-system",
    "test:terminal": "vitest run paste-safety terminal-settings shell-integration settings-persistence-fields",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "check": "npm run typecheck && npm run test && npm run build:renderer",
    "web": "node server/index.cjs",
    "tauri": "tauri",
    "preview": "vite preview",
    "dist": "tauri build",
    "dist:win": "tauri build"
  },
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.2",
    "@tauri-apps/api": "^2.11.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "lucide-react": "^0.563.0",
    "ssh2": "^1.17.0",
    "tailwind-merge": "^2.5.5",
    "ws": "^8.21.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^20.8.7",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react-swc": "^3.6.0",
    "autoprefixer": "^10.4.20",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.0.2",
    "vite": "^5.0.0",
    "vitest": "^2.1.9",
    "wait-on": "^7.2.0"
  },
  "author": "",
  "license": "MIT"
}
